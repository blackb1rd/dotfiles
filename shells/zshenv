# ~/.zshenv — sourced for EVERY zsh: interactive shells, plain scripts, and the
# non-interactive shells that tools/agents (Claude, CI, cron, editors) use to
# run commands. Those never reach ~/.zshrc, so anything they need — PATH and
# environment — belongs here. Keep it fast and SILENT: no prompt, no plugins,
# no command output (stray output here corrupts what a tool reads back).

export LC_ALL=en_US.UTF-8
export LC_CTYPE=en_US.UTF-8

# Rust toolchain (path.sh also handles this; sourcing twice is idempotent).
[ -f "$HOME/.cargo/env" ] && . "$HOME/.cargo/env"

# Shared, POSIX-sh, idempotent helpers + static PATH/env. These define the
# functions (pathadd, AddCurrentUserPath) that ~/.zprofile eval's for a login
# shell, and set the base PATH every shell needs.
source "$HOME/.shells/source/utility.sh"
[ -f "$HOME/.shells/source/environment.sh" ] && source "$HOME/.shells/source/environment.sh"
source "$HOME/.shells/source/path.sh"

# pyenv root on PATH so `pyenv` resolves before ~/.zprofile eval's its init.
export PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT/bin" ]; then
  case ":$PATH:" in
    *":$PYENV_ROOT/bin:"*) ;;
    *) PATH="$PYENV_ROOT/bin:$PATH" ;;
  esac
fi
